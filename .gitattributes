# 源码与文本文件统一 LF 行尾，避免 git 在 Windows checkout 时反复改 CRLF
# 触发原因：之前 git diff/status 频繁报 "LF will be replaced by CRLF"
*.c        text eol=lf
*.h        text eol=lf
*.lsl      text eol=lf
*.ld       text eol=lf
*.ini      text eol=lf
*.cfg      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.lua      text eol=lf

# Windows 脚本保留 CRLF（cmd/PowerShell 期望）
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# 二进制：构建产物 / Debug 输出 / 文档
*.elf      binary
*.hex      binary
*.bin      binary
*.o        binary
*.map      binary
*.mdf      binary
*.src      binary
*.lst      binary
*.pdf      binary
*.png      binary
*.jpg      binary
*.bmp      binary
*.ico      binary
*.zip      binary
*.rar      binary
*.7z       binary

# Tasking IDE 工程文件按原样不动行尾
*.cproject -text
*.project  -text
*.launch   -text
