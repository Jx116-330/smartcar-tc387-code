{
  "permissions": {
    "allow": [
      "Bash(xargs grep:*)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-check.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact-save.sh"
          }
        ]
      }
    ]
  }
}
